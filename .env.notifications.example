# 📧 CONFIGURAÇÕES DE NOTIFICAÇÃO

# ========================================
# 🆓 CONFIGURAÇÃO GRATUITA (RECOMENDADA)
# ========================================

# Providers (troque aqui para mudar facilmente)
NOTIFICATION_EMAIL_PROVIDER=gmail
NOTIFICATION_SMS_PROVIDER=mock

# Gmail SMTP (GRATUITO - 500 emails/dia)
GMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password-here

# ========================================  
# 💰 CONFIGURAÇÕES PAGAS (OPCIONAIS)
# ========================================

# SendGrid (Email Profissional)
SENDGRID_ENABLED=false
SENDGRID_API_KEY=SG.sua-chave-sendgrid
SENDGRID_FROM_EMAIL=noreply@seudominio.com

# AWS SES (Email em Massa)  
AWS_SES_ENABLED=false
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua-chave-aws
AWS_SECRET_ACCESS_KEY=sua-chave-secreta-aws

# Twilio SMS (SMS Real)
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=seu-account-sid
TWILIO_AUTH_TOKEN=seu-auth-token
TWILIO_FROM_PHONE=+5511999999999

# ========================================
# 🏢 DADOS DA EMPRESA
# ========================================

COMPANY_NAME="Oficina Mecânica"
COMPANY_PHONE="(11) 99999-9999"
COMPANY_EMAIL="contato@oficina.com"
COMPANY_WEBSITE="https://oficina.com"

# ========================================
# 🌐 URLs DA APLICAÇÃO
# ========================================

APP_URL=http://localhost:3000

# ========================================
# 🔧 CONFIGURAÇÕES DE DESENVOLVIMENTO
# ========================================

NODE_ENV=development