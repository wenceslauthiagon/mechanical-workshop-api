{
  "info": {
    "name": "Mechanical Workshop - Phase 4",
    "description": "Collection para validar o fluxo Saga dos 3 microserviços (OS, Billing, Execution).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "OS Service",
      "item": [
        {
          "name": "Health - OS",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{os_base_url}}/health",
              "host": ["{{os_base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"cust-001\",\n  \"vehicleId\": \"veh-001\",\n  \"description\": \"Revisão completa e troca de óleo\"\n}"
            },
            "url": {
              "raw": "{{os_base_url}}/orders",
              "host": ["{{os_base_url}}"],
              "path": ["orders"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('order_id', json.id);",
                  "pm.test('order created with OPENED status', function () { pm.expect(json.status).to.eql('OPENED'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Order by Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{os_base_url}}/orders/{{order_id}}",
              "host": ["{{os_base_url}}"],
              "path": ["orders", "{{order_id}}"]
            }
          }
        },
        {
          "name": "Get Order History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{os_base_url}}/orders/{{order_id}}/history",
              "host": ["{{os_base_url}}"],
              "path": ["orders", "{{order_id}}", "history"]
            }
          }
        },
        {
          "name": "Update Order Status -> PAYMENT_CONFIRMED",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PAYMENT_CONFIRMED\"\n}"
            },
            "url": {
              "raw": "{{os_base_url}}/orders/{{order_id}}/status",
              "host": ["{{os_base_url}}"],
              "path": ["orders", "{{order_id}}", "status"]
            }
          }
        },
        {
          "name": "Update Order Status -> COMPLETED",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\"\n}"
            },
            "url": {
              "raw": "{{os_base_url}}/orders/{{order_id}}/status",
              "host": ["{{os_base_url}}"],
              "path": ["orders", "{{order_id}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "Billing Service",
      "item": [
        {
          "name": "Health - Billing",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{billing_base_url}}/health",
              "host": ["{{billing_base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{order_id}}\",\n  \"estimatedTotal\": 1890.50\n}"
            },
            "url": {
              "raw": "{{billing_base_url}}/billing/budget",
              "host": ["{{billing_base_url}}"],
              "path": ["billing", "budget"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('budget_id', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Approve Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"budgetId\": \"{{budget_id}}\",\n  \"amount\": 1890.50\n}"
            },
            "url": {
              "raw": "{{billing_base_url}}/billing/payment/approve",
              "host": ["{{billing_base_url}}"],
              "path": ["billing", "payment", "approve"]
            }
          }
        },
        {
          "name": "Get Billing by Order",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{billing_base_url}}/billing/order/{{order_id}}",
              "host": ["{{billing_base_url}}"],
              "path": ["billing", "order", "{{order_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Execution Service",
      "item": [
        {
          "name": "Health - Execution",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{execution_base_url}}/health",
              "host": ["{{execution_base_url}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "Start Execution",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"{{order_id}}\"\n}"
            },
            "url": {
              "raw": "{{execution_base_url}}/execution/start",
              "host": ["{{execution_base_url}}"],
              "path": ["execution", "start"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('execution_id', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update Execution Status -> COMPLETED",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\",\n  \"note\": \"Execução finalizada\"\n}"
            },
            "url": {
              "raw": "{{execution_base_url}}/execution/{{execution_id}}/status",
              "host": ["{{execution_base_url}}"],
              "path": ["execution", "{{execution_id}}", "status"]
            }
          }
        },
        {
          "name": "Get Execution by Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{execution_base_url}}/execution/{{execution_id}}",
              "host": ["{{execution_base_url}}"],
              "path": ["execution", "{{execution_id}}"]
            }
          }
        },
        {
          "name": "Get Execution by Order",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{execution_base_url}}/execution/order/{{order_id}}",
              "host": ["{{execution_base_url}}"],
              "path": ["execution", "order", "{{order_id}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "os_base_url",
      "value": "http://localhost:3001"
    },
    {
      "key": "billing_base_url",
      "value": "http://localhost:3002"
    },
    {
      "key": "execution_base_url",
      "value": "http://localhost:3003"
    },
    {
      "key": "order_id",
      "value": ""
    },
    {
      "key": "budget_id",
      "value": ""
    },
    {
      "key": "execution_id",
      "value": ""
    }
  ]
}
