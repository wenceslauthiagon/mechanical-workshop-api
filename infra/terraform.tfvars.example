database_password = "workshop123"
jwt_secret        = "your-super-secret-jwt-key-change-in-production"
kubeconfig_path   = "~/.kube/config"
kube_context      = "docker-desktop"
namespace         = "mechanical-workshop"
app_name          = "workshop-api"
app_replicas      = 3
app_image         = "workshop-api:latest"
provision_oci_cluster = false

# OCI example variables (leave empty if not provisioning OCI resources)
oci_tenancy_ocid       = ""
oci_user_ocid          = ""
oci_fingerprint        = ""
oci_private_key_path   = "~/.oci/oci_api_key.pem"
oci_region             = "us-ashburn-1"
oci_compartment_ocid   = ""

# Networking and node defaults for OCI provisioning
oci_vcn_cidr    = "10.0.0.0/16"
oci_subnet_cidr = "10.0.1.0/24"
node_shape      = "VM.Standard.E3.Flex"
node_count      = 3
node_image_id   = "" # set your region image OCID if provisioning OCI nodes
